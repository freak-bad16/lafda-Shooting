# Copy this file to .env and fill in the values.
# In Railway: set these as Environment Variables in the service settings.

# The PORT is automatically set by Railway — do not set this manually.
# PORT=5000

# The Vercel URL of your deployed web app (no trailing slash).
# Example: https://your-app.vercel.app
# Set to * during local development to allow all origins.
ALLOWED_ORIGIN=*
